{
    "name": "teknoo/east-translation-symfony",
    "type": "metapackage",
    "description": "Metapackage to install Teknoo East Translation in Symfony, Package following the #East programming philosophy, to make easily translatable objects",
    "keywords": ["east","translation","cms"],
    "homepage": "http://teknoo.software/east/translation",
    "license": ["BSD-3-Clause"],
    "authors": [
        {
            "name": "Richard Déloge",
            "email": "richard@teknoo.software",
            "role": "Software architect, Lead developer"
        }
    ],
    "support": {
        "issues": "https://github.com/TeknooSoftware/east-translation-symfony/issues",
        "source": "https://github.com/TeknooSoftware/east-translation-symfony"
    },
    "funding": [
        {
            "type": "patreon",
            "url": "https://www.patreon.com/teknoo_software"
        },
        {
            "type": "github",
            "url": "https://github.com/sponsors/TeknooSoftware"
        }
    ],
    "require": {
        "ext-simplexml" : "*",
        "ext-mongodb" : "*",
        "doctrine/common": "^3.5",
        "doctrine/mongodb-odm": "^2.11.3",
        "doctrine/mongodb-odm-bundle": "^5.3.1",
        "doctrine/persistence": "^4",
        "php-di/php-di": "^7.1.1",
        "symfony/form": "^6.4.24||^7.3",
        "teknoo/bridge-phpdi-symfony": "^7.1",
        "teknoo/east-common-symfony": "^4",
        "teknoo/east-foundation-symfony": "^9",
        "teknoo/recipe": "^7",
        "teknoo/east-translation": "^2"
    },
    "require-dev": {
        "roave/security-advisories": "dev-latest"
    },
    "extra": {
        "symfony" : {
            "endpoint": [
                "https://api.github.com/repos/TeknooSoftware/symfony-recipes/contents/index.json",
                "flex://defaults"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "teknoo/composer-install": true
        }
    }
}
